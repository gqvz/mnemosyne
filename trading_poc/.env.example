# Mnemosyne Trading PoC — Environment Variables
# Copy this file to .env and fill in your values

# ─── Sui Wallet ────────────────────────────────────────────────────────────────
# Master wallet private key (used to bootstrap the namespace and fund agents)
SUI_PRIVATE_KEY=suiprivkey1q...

# ─── Contract ──────────────────────────────────────────────────────────────────
# Deployed Mnemosyne package ID on your target network
MNEMOSYNE_PACKAGE_ID=0x<your_package_id>

# ─── Network ───────────────────────────────────────────────────────────────────
# testnet | mainnet
SUI_NETWORK=testnet

# Optional: override the Sui RPC endpoint
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ─── MemWal (Walrus relayer) ───────────────────────────────────────────────────
MEMWAL_ACCOUNT_ID=<your_memwal_account_id>
MEMWAL_PRIVATE_KEY=<your_memwal_private_key>

# Optional: override the MemWal server URL (defaults to https://relayer.memwal.ai)
# MEMWAL_SERVER_URL=https://relayer.memwal.ai
